# Copy to `.env` in the repo root for: docker compose -f docker-compose.prod.yml up -d

# --- Database (docker-compose service name `db`) ---
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@db:5432/averda_academy

# --- Auth (generate long random strings) ---
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars
SETTINGS_SECRET=CHANGE_ME_settings_encryption_secret

# --- Public URL (scheme + host; used for CORS) ---
CLIENT_URL=https://averdaacademy.ma

# --- Optional AI keys (set via Admin > Settings or here) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# --- Runtime ---
PORT=3011
UPLOAD_DIR=/data/uploads
NODE_ENV=production
SERVE_CLIENT=true

# --- Entrypoint ---
# RUN_MIGRATIONS=true   # apply prisma migrate deploy on start
# RUN_SEED=false        # set true only for first-time demo/staging (known demo PINs!)

# --- Postgres container (must match DATABASE_URL user/password) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=averda_academy
